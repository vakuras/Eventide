{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/v2/tooling/cli/schema.json",
  "productName": "Eventide",
  "version": "0.6.8",
  "identifier": "com.vakuras.eventide",
  "build": {
    "frontendDist": "../dist-tauri",
    "beforeDevCommand": "npm run tauri:frontend",
    "beforeBuildCommand": "npm run tauri:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Eventide",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "../resources/32x32.png",
      "../resources/128x128.png",
      "../resources/128x128@2x.png",
      "../resources/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "publisher": "vakuras",
    "resources": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/vakuras/Eventide/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUxOUM0RUM4MDdBNEE3QkQKUldTOXA2UUh5RTZjNFZxaVJpWk9uWllEV2tIcWF5WG1VVlJXQjVxT1lDb3Bvbnk3S3k1ZmcxWXQK"
    }
  }
}

